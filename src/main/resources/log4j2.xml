<?xml version="1.0" encoding="UTF-8"?>
<Configuration packages="org.apache.logging.log4j.core">
    <Appenders>
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <!-- Local time zone -->
            <!-- PatternLayout pattern="%d{ISO8601} [%t] %-5p %c{1} - %m%n" /-->
            <!-- UTC time zone -->
            <PatternLayout pattern="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}{UTC} [%t] %-5p %c{1} - %m%n" />
        </Console>
        <File name="FileAppender" fileName="snmp-mock-agent.log">
            <!-- Local time zone -->
            <!-- PatternLayout pattern="%d{ISO8601} [%t] %-5p %c{1} - %m%n" /-->
            <!-- UTC time zone -->
            <PatternLayout pattern="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}{UTC} [%t] %-5p %c{1} - %m%n" />
        </File>
    </Appenders>
    <Loggers>
        <Logger name="at.kaismi.snmpmockagent" level="info" />
        <Root level="info">
            <AppenderRef ref="ConsoleAppender" />
            <!-- AppenderRef ref="FileAppender" /-->
        </Root>
    </Loggers>
</Configuration>